<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#101820">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Aircraft War"
        android:textColor="#FFFFFF"
        android:textSize="34sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose difficulty or view rankings"
        android:textColor="#C6D4DF"
        android:textSize="16sp"
        android:layout_marginBottom="28dp" />

    <TextView
        android:id="@+id/tvCloudInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cloud: difficulty 1, coins 0"
        android:textColor="#8FB7D8"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchAudio"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:text="Audio"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/btnEasy"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:text="Easy"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnNormal"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:text="Normal"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnHard"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:text="Hard"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnOnline"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:text="Online Battle (Socket)"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnRankings"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:text="Rankings" />

</LinearLayout>
